// Types use ... -> ... and functions fn ... => ...

// 1: Unit type and value also called top
let Unit: Type = (A: Type) -> A -> A;
let unit: Unit = fn (A: Type) (x: A) => x;

// 2: Never type (aka Bottom/False)
let Never: Type = fn (A: Type) => A;

// 3: Natural numbers
let Nat: Type = (A: Type) -> (A -> A) -> A -> A;
let zero: Nat = fn (A: Type) (f: A -> A) (x: A) => x;
let succ: Nat -> Nat = fn (n: Nat) (A: Type) (f: A -> A) (x: A) => f (n A f x);
let add: Nat -> Nat -> Nat = fn (m: Nat) (n: Nat) (A: Type) (f: A -> A) (x: A) => m A f (n A f x);
let mul: Nat -> Nat -> Nat = fn (m: Nat) (n: Nat) (A: Type) (f: A -> A) => m A (n A f);
// exponentiation
let exp: Nat -> Nat -> Nat = fn (m: Nat) (n: Nat) => n Nat (mul m) (succ zero);

// Booleans (not to be confused with bottom and top)
let Bool: Type = (A: Type) -> A -> A -> A;
let true: Bool = fn (A: Type) (t: A) (f: A) => t;
let false: Bool = fn (A: Type) (t: A) (f: A) => f;

let Pair: (A: Type) -> (B: Type) -> Type = fn (A: Type) (B: Type) => ((C: Type) -> (A -> B -> C) -> C);
let pair: (A: Type) -> (B: Type) -> A -> B -> Pair A B = fn (A: Type) (B: Type) (a: A) (b: B) => fn (C: Type) (f: A -> B -> C) => f a b;

// These are the projections
let fst: (A: Type) -> (B: Type) -> Pair A B -> A = fn (A: Type) (B: Type) (p: Pair A B) => p A (fn (a: A) (b: B) => a);
let snd: (A: Type) -> (B: Type) -> Pair A B -> B = fn (A: Type) (B: Type) (p: Pair A B) => p B (fn (a: A) (b: B) => b);

let Either: Type -> Type -> Type = fn (A: Type) (B: Type) => (C: Type) -> (A -> C) -> (B -> C) -> C;
let left: (A: Type) -> (B: Type) -> A -> Either A B = fn (A: Type) (B: Type) (a: A) (C: Type) (f: A -> C) (g: B -> C) => f a;
let right: (A: Type) -> (B: Type) -> B -> Either A B = fn (A: Type) (B: Type) (b: B) (C: Type) (f: A -> C) (g: B -> C) => g b;
let either: (A: Type) -> (B: Type) -> Either A B -> (A -> C) -> (B -> C) -> C =
  fn (A: Type) (B: Type) (e: Either A B) (C: Type) (f: A -> C) (g: B -> C) => e C f g;

// weird parsing error with ((X: Type) -> T X -> R)
// let Exists: (Type -> Type) -> Type = fn (T: Type -> Type) (R: Type) ((X: Type) -> T X -> R) => R;
let pack: (T: Type -> Type) -> (X: Type) -> T X -> Exists T =
  fn (T: Type -> Type) (X: Type) (tx: T X) (R: Type) (k: (X: Type) -> T X -> R) => k X tx;
let unpack: (T: (X: Type) -> Type) -> Exists T -> (R: Type) -> ((X: Type) -> T X -> R) -> R =
  fn (T: (X: Type) -> Type) (e: Exists T) (R: Type) (k: (X: Type) -> T X -> R) => e R k;

let Eq: (A: Type) -> A -> A -> Type = fn (A: Type) (x: A) (y: A) (P: A -> Type) (px: P x) => P y;
let Equiv: (A: Type) -> (B: Type) -> (f: A -> B) -> (g: A -> B) -> Type = fn (A: Type) (B: Type) (f: A -> B) (g: A -> B) (x: A) => Eq B (f x) (g x);
let refl: (A: Type) -> (x: A) -> Eq A x x = fn (A: Type) (x: A) (P: A -> Type) (px: P x) => px;

let InverseLeft: (A: Type) -> (B: Type) -> (f: A -> B) -> (g: B -> A) -> Type =
  fn (A: Type) (B: Type) (f: A -> B) (g: B -> A) (x: A) => Eq A (g (f x)) x;
let InverseRight: (A: Type) -> (B: Type) -> (f: A -> B) -> (g: B -> A) -> Type =
  fn (A: Type) (B: Type) (f: A -> B) (g: B -> A) (y: B) => Eq B (f (g y)) y;
let Inverse: (A: Type) -> (B: Type) -> (f: A -> B) -> (g: B -> A) -> Type =
  fn (A: Type) (B: Type) (f: A -> B) (g: B -> A) => Pair ((x: A) -> Eq A (g (f x)) x) ((y: B) -> Eq B (f (g y)) y);

let Int: Type = fn (X: Type) (x: X) (f: X -> X) (g: X -> X) (proof: Inverse X X f g) => X;
let int_zero: Int = fn (X: Type) (x: X) (f: X -> X) (g: X -> X) (proof: Inverse X X f g) => x;
let int_succ: Int -> Int = fn (n: Int) (X: Type) (x: X) (f: X -> X) (g: X -> X) (proof: Inverse X X f g) => f (n X x f g proof);
let int_pred: Int -> Int = fn (n: Int) (X: Type) (x: X) (f: X -> X) (g: X -> X) (proof: Inverse X X f g) => g (n X x f g proof);

// u8 definition (subtraction is not possible if build on Nats)
let two: Nat = succ succ zero;
let eight: Nat = succ succ succ succ succ succ succ succ zero;
let pow_2_8: Nat = exp two eight;
let U8: Type = fn (A: Type) (f: A -> A) (x: A) (p: Eq (pow_2_8 A f x)) => A;

let u8_zero: U8 = fn (A: Type) (f: A -> A) (x: A) (p: Eq (pow_2_8 A f x) x) => x;
let u8_succ: U8 -> U8 = fn (n: U8) (A: Type) (f: A -> A) (x: A) (p: Eq (pow_2_8 A f x) x) => f (n A f x p);
unit
