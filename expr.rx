// def six: Nat := 

// ty.rx----------------------------------------------------------------------------
//


def map_i_expr_B_unit (T: Type) (e: I_expr T): Expr Nat Unit T := map_expr_B Nat String T e Unit ((x: String) => unit)

def eq (T: Type) (e1: I_expr T) (e2: I_expr T) (e1_eq_e2: Dec_eq (Expr Nat Unit T) (map_i_expr_B_unit T e1) (map_i_expr_B_unit T e2)): Bool := 
    e1_eq_e2 Bool ((x: Eq (Expr Nat Unit T) (map_i_expr_B_unit T e1) (map_i_expr_B_unit T e2)) => true) ((x: Not (Eq (Expr Nat Unit T) (map_i_expr_B_unit T e1) (map_i_expr_B_unit T e2))) => false)

