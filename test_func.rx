// Types use ... -> ... and functions use ... => ...both are right associative
 

// Unit (Top/True)
def unit (A: Type) (x: A) : A := x

// Never (Bottom/False)
def Never: Type := (A: Type) -> A

// Natural numbers
def Nat: Type := (A: Type) -> (A -> A) -> A -> A

def zero: Nat := (A: Type) => (f: A -> A) => (x: A) => x

// if we defined it like this: "def succ (n: Nat): Nat := (A: Type) => (f: A -> A) => (x: A) => f (n A f x)" in the current version
// it would expand to "succ: Nat -> Nat := (n: Nat) => (A: Type) => (f: A -> A) => (x: A) => f (n A f x)" which is invalid because Nat shows up in the value where
// it is still an unknown value. In the future the expansion will be different so it should work correctly. The param_ty field of the lambda might even be removed entirely

def succ (n: Nat): Nat := (A: Type) => (f: A -> A) => (x: A) => f (n A f x)


def add (m: (A: Type) -> (A -> A) -> A -> A) (n: (A: Type) -> (A -> A) -> A -> A): Nat := (A: Type) => (f: A -> A) => (x: A) => m A f (n A f x)
def mul (m: (A: Type) -> (A -> A) -> A -> A) (n: (A: Type) -> (A -> A) -> A -> A): Nat := (A: Type) => (f: A -> A) => (x: A) => m A (n A f) x
// Wait should this be repeated multiplication or should this be n m
def exp (m: (A: Type) -> (A -> A) -> A -> A) (n: (A: Type) -> (A -> A) -> A -> A): Nat := (A: Type) => (f: A -> A) => (x: A) => n (A -> A) (m A) f x

// Booleans (not to be confused with bottom and top)
def Bool: Type := (A: Type) -> A -> A -> A
def true: Bool := (A: Type) => (t: A) => (f: A) => t
def false: Bool := (A: Type) => (t: A) => (f: A) => f


def Pair (A: Type) (B: Type): Type := (C: Type) -> (A -> B -> C) -> C
def pair (A: Type) (B: Type) (a: A) (b: B): Pair A B := (C: Type) => (f: A -> B -> C) => f a b

// note: Sigma A (_ => B) = Pair A B
def Sigma (A: Type) (B: A -> Type): Type := (C: Type) -> ((a: A) -> B a -> C) -> C
def sigma (A: Type) (B: A -> Type) (a: A) (b: B a): Sigma A B := (C: Type) => (f: (a: A) -> B a -> C) => f a b

// These are the projections
// def fst (A: Type) (B: Type) (p: Pair A B): A := p A ((a: A) => (b: B) => a)
// def snd (A: Type) (B: Type) (p: Pair A B): B := p B ((a: A) => (b: B) => b)

def Either (A: Type) (B: Type): Type := (C: Type) -> (A -> C) -> (B -> C) -> C
def left (A: Type) (B: Type) (a: A): Either A B := (C: Type) => (f: A -> C) => (g: B -> C) => f a
def right (A: Type) (B: Type) (b: B): Either A B := (C: Type) => (f: A -> C) => (g: B -> C) => g b
// def match (A: Type) (B: Type) (e: Either A B) (f: A -> C) (g: B -> C): C := e C f g

// note: "Sigma Type ((X: Type) => T X) = (R: Type) -> ((X: Type) -> T X -> R) -> R"
def Exists (T: Type -> Type): Type := Sigma Type ((X: Type) => T X)
// def pack (T: Type -> Type) (X: Type) (tx: T X): Exists T := ?
// def unpack (T: Type -> Type) (e: Exists T) (R: Type) (k: (X: Type) -> T X -> R): R := e R k

def Eq (A: Type) (x: A) (y: A): Type := (P: A -> Type) -> P x -> P y
def refl (A: Type) (x: A): Eq A x x := (P: A -> Type) => (p: P x) => p

// Pointwise equality
def Equiv (A: Type) (B: Type) (f: A -> B) (g: A -> B) : Type := (a: A) -> Eq B (f a) (g a)
// A function is pointwise equal to itself
def equiv_refl (A: Type) (B: Type) (f: A -> B) : Equiv A B f f := (a: A) => refl B (f a)

def InverseLeft (A: Type) (B: Type) (f: A -> B) (g: B -> A): Type :=
    (x: A) -> Eq A (g (f x)) x

def InverseRight (A: Type) (B: Type) (f: A -> B) (g: B -> A): Type :=
    (y: B) -> Eq B (f (g y)) y

def Inverse (A: Type) (B: Type) (f: A -> B) (g: B -> A): Type :=
    Pair ((x: A) -> Eq A (g (f x)) x) ((y: B) -> Eq B (f (g y)) y)

def Int: Type := (X: Type) -> (x: X) -> (f: X -> X) -> (g: X -> X) -> (p: Inverse X X f g) -> X
def int_zero: Int := (X: Type) => (x: X) => (f: X -> X) => (g: X -> X) => (p: Inverse X X f g) => x
//def int_succ (n: Int): Int := (X: Type) => (x: X) => (f: X -> X) => (g: X -> X) => (p: Inverse X X f g) => f (n X x f g p)
//def int_pred (n: Int): Int := (X: Type) => (x: X) => (f: X -> X) => (g: X -> X) => (p: Inverse X X f g) => g (n X x f g p)

// U8 definition (built on Nats)
def two: Nat := succ succ zero
def eight: Nat := succ succ succ succ succ succ succ succ zero
def pow_2_8: Nat := exp two eight

def U8: Type := (A: Type) => (f: A -> A) => (x: A) => (p: Eq (pow_2_8 A f x)) => A
def u8_zero: U8 := (A: Type) => (f: A -> A) => (x: A) => (p: Eq (pow_2_8 A f x) x) => x
//def u8_succ (n: U8): U8 := (A: Type) => (f: A -> A) => (x: A) => (p: Eq (pow_2_8 A f x) x) => f (n A f x p)

def Y_combinator (A: Type) (f: A -> A) : A :=
  ((x: (X: Type) -> X -> A) => f (x x))
  ((x: (X: Type) -> X -> A) => f (x x))


